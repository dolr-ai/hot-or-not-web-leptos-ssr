{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cargo leptos watch",
            "type": "shell",
            "group": "build",
            "command": "cargo",
            "args": [
                "leptos",
                "watch",
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "dedicated",
                "showReuseMessage": false,
                "clear": false,
                "group": "${cwd}"
            }
        },
        {
            "label": "ci: cargo fmt --check",
            "type": "shell",
            "command": "cargo fmt --check",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "showReuseMessage": false,
                "clear": false
            }
        },
        {
            "label": "ci: cargo clippy",
            "type": "shell",
            "command": "cargo clippy --no-deps --all-features --release -- -Dwarnings",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "showReuseMessage": false,
                "clear": false
            }
        },
        {
            "label": "ci: cargo leptos build --release",
            "type": "shell",
            "command": "cargo leptos build --release --lib-features release-lib --bin-features release-bin",
            "options": {
                "env": {
                    "LEPTOS_HASH_FILES": "true"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "showReuseMessage": false,
                "clear": false
            }
        },
        {
            "label": "ci: build-check",
            "dependsOrder": "sequence",
            "dependsOn": [
                "ci: cargo fmt --check",
                "ci: cargo clippy",
                "ci: cargo leptos build --release"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            }
        }
    ]
}