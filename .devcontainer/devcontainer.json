{
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        // docker
        "ms-azuretools.vscode-containers",
        // editor
        "albert.TabOut",
        // github
        "mhutchie.git-graph",
        "github.vscode-github-actions",
        "GitHub.vscode-pull-request-github",
        // rust
        "fill-labs.dependi",
        "tamasfe.even-better-toml",
        "rust-lang.rust-analyzer",
        "vadimcn.vscode-lldb",
        // tailwindcss
        "bradlc.vscode-tailwindcss",
        // git
        "eamodio.gitlens"
      ]
    }
  },
  "features": {
    // rust toolchain
    "ghcr.io/devcontainers/features/rust:1": {},
    // for clang required to build ring
    "ghcr.io/devcontainers-community/features/llvm": {},
    // build dependency for ml-feed-server bindings
    "ghcr.io/devcontainers-extra/features/protoc:1": {}
  },
  // bind-mounts for local dev: SSH agent forwarding and gh CLI config.
  // CI creates placeholder files/dirs for these before starting the container.
  "mounts": [
    "type=bind,source=${env:HOME}/.ssh/agent.sock,target=/ssh-agent,consistency=cached",
    "type=bind,source=${env:HOME}/.config/gh,target=/home/vscode/.config/gh,consistency=cached"
  ],
  "remoteEnv": {
    "SSH_AUTH_SOCK": "/ssh-agent"
  },
  "onCreateCommand": "rustup install;",
  "postCreateCommand": "bash .devcontainer/setup.sh"
}